# Copy to .env and fill in real values. Never commit .env.

# Server
PORT=3000
BASE_URL=https://mail.andreatarroni.com

# PostgreSQL
DATABASE_URL=postgres://email_os:password@localhost:5432/email_os

# Amazon SES — sends from a dedicated subdomain to isolate sending
# reputation from the root domain's regular email deliverability.
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_ADDRESS=newsletter@mail.andreatarroni.com

# SNS webhook (bounce/complaint notifications) — must be a public HTTPS path
SNS_WEBHOOK_PATH=/webhooks/ses-notifications

# API auth for the draft-campaign endpoint (used by Andrea's HTML-generation workflow)
DRAFT_API_KEY=

# HTTP Basic Auth credentials protecting the admin UI (/contacts, /campaigns)
ADMIN_USERNAME=
ADMIN_PASSWORD=
