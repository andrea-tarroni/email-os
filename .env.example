# Copy to .env and fill in real values. Never commit .env.

# Server
PORT=3000
BASE_URL=https://mail.andreatarroni.com

# PostgreSQL
DATABASE_URL=postgres://email_os:password@localhost:5432/email_os

# Resend — sends from a dedicated subdomain to isolate sending
# reputation from the root domain's regular email deliverability.
# Use the same RESEND_API_KEY as the Members Area project.
RESEND_API_KEY=
MAIL_FROM_ADDRESS=Andrea Tarroni <newsletter@mail.andreatarroni.com>

# SNS webhook (bounce/complaint notifications from SES) — kept in place
# for the future SES migration; unused while sending via Resend.
SNS_WEBHOOK_PATH=/webhooks/ses-notifications

# API auth for the draft-campaign endpoint (used by Andrea's HTML-generation workflow)
DRAFT_API_KEY=

# HTTP Basic Auth credentials protecting the admin UI (/contacts, /campaigns)
ADMIN_USERNAME=
ADMIN_PASSWORD=
