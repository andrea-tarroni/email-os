<!DOCTYPE html>
<html>
<head>
  <title>Contacts — Email OS</title>
  <link rel="stylesheet" href="/admin.css">
</head>
<body>
  <div class="admin-container">
    <nav class="admin-nav">
      <span class="brand">Email OS</span>
      <a href="/contacts" class="active">Contacts</a>
      <a href="/campaigns">Campaigns</a>
    </nav>

    <h2>Contacts</h2>
    <div class="status-counts">
      <a href="/contacts" class="<%= statusFilter ? '' : 'active' %>">All</a>
      <% counts.forEach(c => { %>
        <a href="/contacts?status=<%= c.status %>" class="<%= statusFilter === c.status ? 'active' : '' %>"><%= c.status %> (<%= c.count %>)</a>
      <% }) %>
    </div>

    <p style="margin-bottom: 20px;"><a href="/contacts/new" class="btn">+ Add contact</a></p>

    <table class="admin-table">
      <tr><th>Email</th><th>Name</th><th>Source</th><th>Status</th><th>Created</th><th></th></tr>
      <% contacts.forEach(c => { %>
        <tr>
          <td><%= c.email %></td>
          <td><%= c.name || "—" %></td>
          <td><%= c.source || "—" %></td>
          <td><span class="badge badge-<%= c.status %>"><%= c.status %></span></td>
          <td class="muted"><%= c.created_at.toISOString().slice(0,10) %></td>
          <td>
            <form method="post" action="/contacts/<%= c.id %>/delete" class="delete-form">
              <button type="submit" class="btn-outline btn-small" onclick="return confirm('Delete this contact?')">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </table>
  </div>
</body>
</html>
