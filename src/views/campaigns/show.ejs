<!DOCTYPE html>
<html>
<head><title><%= campaign.subject %> — Email OS</title></head>
<body style="font-family: sans-serif; max-width: 800px; margin: 2em auto;">
  <h1>Email OS</h1>
  <nav><a href="/contacts">Contacts</a> | <a href="/campaigns">Campaigns</a></nav>

  <h2><%= campaign.subject %></h2>
  <p>Status: <strong><%= campaign.status %></strong></p>

  <% if (campaign.status === "draft") { %>
    <form method="post" action="/campaigns/<%= campaign.id %>/send">
      <button type="submit" onclick="return confirm('Send this campaign to all active contacts now?')">
        Send now
      </button>
    </form>
  <% } %>

  <h3>Preview</h3>
  <iframe srcdoc="<%= campaign.html %>"
          style="width: 100%; height: 500px; border: 1px solid #ccc;"></iframe>
</body>
</html>
