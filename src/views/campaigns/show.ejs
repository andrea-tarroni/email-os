<!DOCTYPE html>
<html>
<head>
  <title><%= campaign.subject %> — Email OS</title>
  <link rel="stylesheet" href="/admin.css">
</head>
<body>
  <div class="admin-container">
    <nav class="admin-nav">
      <span class="brand">Email OS</span>
      <a href="/contacts">Contacts</a>
      <a href="/campaigns" class="active">Campaigns</a>
      <a href="/tags">Tags</a>
    </nav>

    <h2><%= campaign.subject %></h2>
    <p style="margin-bottom: 16px;">Status: <span class="badge badge-<%= campaign.status %>"><%= campaign.status %></span></p>

    <% if (campaign.status === "draft") { %>
      <form method="post" action="/campaigns/<%= campaign.id %>/send" style="margin-bottom: 24px;">
        <button type="submit" class="btn" onclick="return confirm('Send this campaign to all active contacts now?')">
          Send now
        </button>
      </form>
    <% } %>

    <h3>Preview</h3>
    <iframe srcdoc="<%= campaign.html %>" class="preview-frame"></iframe>
  </div>
</body>
</html>
