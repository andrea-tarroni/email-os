<!DOCTYPE html>
<html>
<head><title>Unsubscribed — Email OS</title></head>
<body style="font-family: sans-serif; max-width: 600px; margin: 4em auto; text-align: center;">
  <% if (found) { %>
    <h1>You've been unsubscribed</h1>
    <p>You will no longer receive emails from this list.</p>
  <% } else { %>
    <h1>Link not recognized</h1>
    <p>This unsubscribe link is invalid or has already been used.</p>
  <% } %>
</body>
</html>
