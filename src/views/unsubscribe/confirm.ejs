<!DOCTYPE html>
<html>
<head>
  <title>Unsubscribed — Email OS</title>
  <link rel="stylesheet" href="/admin.css">
</head>
<body>
  <div class="center-page">
    <% if (found) { %>
      <h1>You've been unsubscribed</h1>
      <p class="muted">You will no longer receive emails from this list.</p>
    <% } else { %>
      <h1>Link not recognized</h1>
      <p class="muted">This unsubscribe link is invalid or has already been used.</p>
    <% } %>
  </div>
</body>
</html>
